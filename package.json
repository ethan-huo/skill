{
  "name": "skill",
  "version": "0.1.0",
  "description": "Install and remove agent skills from GitHub repositories.",
  "bin": {
    "skill": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "fmt": "bunx oxfmt .",
    "fmt:check": "bunx oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "check": "bun run fmt:check && bun run typecheck && bun test"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@valibot/to-json-schema": "^1.6.0",
    "argc": "github:ethan-huo/argc#v0.0.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "oxfmt": "^0.46.0",
    "typescript": "npm:@typescript/typescript6@^6.0.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
